<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#FFFFFF"
    android:padding="14dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp">

    <!-- Product image with rounded corners -->
    <ImageView
        android:id="@+id/ivProductImage"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_product_image"
        android:clipToOutline="true"
        android:importantForAccessibility="no" />

    <!-- Info column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="#E8622A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Rating row: ★ 4.8 (150) • Đã bán 350 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★"
                android:textColor="#F4A835"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="3dp"
                android:textColor="#777777"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="5dp"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:text="•"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvSoldCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#777777"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Add button: dark brown circle -->
    <ImageView
        android:id="@+id/ivAddToCart"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_add_btn_brown"
        android:padding="9dp"
        android:src="@android:drawable/ic_input_add"
        android:tint="#FFFFFF"
        android:importantForAccessibility="no" />

</LinearLayout>
