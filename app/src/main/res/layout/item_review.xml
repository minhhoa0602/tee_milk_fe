<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_review.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Row: Avatar + Tên + Ngày -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Avatar chữ cái đầu -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_circle">

            <TextView
                android:id="@+id/tvAvatarLetter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Tên + Ngày -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReviewerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A1A1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Sao -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <ImageView android:layout_width="12dp" android:layout_height="12dp"
                    android:id="@+id/star1" android:src="@android:drawable/star_on" app:tint="#FFB800"/>
                <ImageView android:layout_width="12dp" android:layout_height="12dp"
                    android:id="@+id/star2" android:src="@android:drawable/star_on" app:tint="#FFB800" android:layout_marginStart="2dp"/>
                <ImageView android:layout_width="12dp" android:layout_height="12dp"
                    android:id="@+id/star3" android:src="@android:drawable/star_on" app:tint="#FFB800" android:layout_marginStart="2dp"/>
                <ImageView android:layout_width="12dp" android:layout_height="12dp"
                    android:id="@+id/star4" android:src="@android:drawable/star_on" app:tint="#FFB800" android:layout_marginStart="2dp"/>
                <ImageView android:layout_width="12dp" android:layout_height="12dp"
                    android:id="@+id/star5" android:src="@android:drawable/star_on" app:tint="#FFB800" android:layout_marginStart="2dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Ngày -->
        <TextView
            android:id="@+id/tvReviewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Comment -->
    <TextView
        android:id="@+id/tvReviewComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="46dp"
        android:textColor="#555555"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#F5F5F5" />

</LinearLayout>